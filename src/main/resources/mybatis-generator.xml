<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration PUBLIC
        "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">
<generatorConfiguration>
    <context id="SQLiteTables" targetRuntime="MyBatis3DynamicSql"> <!-- 或使用 MyBatis3Simple -->

        <!-- 注释生成器配置 -->
        <commentGenerator>
            <property name="suppressAllComments" value="true"/>   <!-- 取消所有注释 -->
            <property name="suppressDate" value="true"/>          <!-- 取消注释中的时间戳 -->
        </commentGenerator>

        <!-- 🌟 数据库连接配置 -->
        <jdbcConnection driverClass="org.sqlite.JDBC"
                        connectionURL="jdbc:sqlite::resources:cms.db"
                        userId=""
                        password="">
        </jdbcConnection>

        <!-- Java实体类生成位置 -->
        <javaModelGenerator targetPackage="com.cms.entity" targetProject="src/main/java">
            <property name="enableSubPackages" value="true"/>
        </javaModelGenerator>

        <!-- Mapper接口生成位置 -->
        <javaClientGenerator type="ANNOTATEDMAPPER" targetPackage="com.cms.mapper" targetProject="src/main/java">
            <property name="enableSubPackages" value="true"/>
        </javaClientGenerator>

        <!-- 🌟 指定要生成代码的表 -->
        <table schema="" tableName="your_table_name"/>
    </context>
</generatorConfiguration>